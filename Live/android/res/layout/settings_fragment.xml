<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background image — equivalent to UIImageView lighted-stage sent to back -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/lighted_stage"
        android:scaleType="centerCrop" />

    <!-- Equivalent to UIStackView vertical: showLabel + textView -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- Equivalent to showLabel UILabel -->
        <TextView
            android:id="@+id/showLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-- no show loaded --"
            android:textSize="35sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="#F2F2F7"
            android:layout_marginBottom="16dp" />

        <!-- Equivalent to textView UITextView scrollable and read-only -->
        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:textSize="16sp"
            android:padding="8dp"
            android:background="#F2F2F7"
            android:scrollbars="vertical"
            android:focusable="false"
            android:clickable="false" />

    </LinearLayout>

</FrameLayout>