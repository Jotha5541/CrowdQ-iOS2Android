<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background image — equivalent to UIImageView lighted-stage sent to back -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/lighted_stage"
        android:scaleType="centerCrop" />

    <!-- Scrollable stack — equivalent to ScrollingTextPage + UIStackView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- instructions -->
            <TextView
                android:id="@+id/instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:padding="8dp"
                android:background="#F2F2F7"
                android:textColor="#000000"
                android:layout_marginBottom="16dp" />

            <!-- emailTextField -->
            <EditText
                android:id="@+id/emailTextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="email for verification..."
                android:textSize="22sp"
                android:background="#F2F2F7"
                android:padding="8dp"
                android:inputType="textEmailAddress"
                android:imeOptions="actionDone"
                android:layout_marginBottom="16dp" />

            <!-- statusButton verify -->
            <Button
                android:id="@+id/verifyButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="verify"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#804FC3F7"
                android:layout_marginBottom="16dp" />

            <!-- unsubscribeButton -->
            <Button
                android:id="@+id/unsubscribeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="unsubscribe"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#804FC3F7" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>